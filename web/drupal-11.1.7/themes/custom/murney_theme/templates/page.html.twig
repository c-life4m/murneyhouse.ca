{#
  /**
   * @file
   * Theme override to display a single page.
   *
   * The doctype, html, head and body tags are not in this template. Instead
   * they can be found in the html.html.twig template in the core themes'
   * templates directory.
   *
   * Available variables:
   *
   * General:
   * - logged_in: A flag indicating if user is logged in.
   * - root_path: The root path of the current page (e.g. node, admin, user).
   * - node_type: The content type for the current node, if the page is a
   *   node page.
   * - db_offline: A flag indicating if the database is offline.
   * - placeholder_token: The token for visitors to use when implementing
   *   the placeholder module over in the backend.
   *
   * Head and body tags:
   * - head_title: List of text elements that make up the head title
   *   (defined in template_preprocess_html()).
   * - page_title: The page title, for use in the actual HTML content.
   * - head: Markup for the HEAD section (tags, meta data, etc.).
   * - attributes: HTML attributes for the BODY tag.
   *
   * Regions:
   * - page.header: Items for the header region.
   * - page.primary_menu: Items for the primary menu region.
   * - page.secondary_menu: Items for the secondary menu region.
   * - page.highlighted: Items for the highlighted content region.
   * - page.help: Dynamic help text, mostly for admin pages.
   * - page.content: The main content of the current page.
   * - page.sidebar_first: Items for the first sidebar.
   * - page.sidebar_second: Items for the second sidebar.
   * - page.footer: Items for the footer region.
   * - page.breadcrumb: Items for the breadcrumb region.
   *
   * @see template_preprocess_page()
   * @see html.html.twig
   */
#}
<div class="layout-container">

  <header role="banner">
    {{ page.header }} {# This will render anything placed in the 'header' region #}
  </header>

  {% if page.primary_menu or page.secondary_menu %}
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      {{ page.primary_menu }}
      {{ page.secondary_menu }}
    </nav>
  {% endif %}

  {% if page.breadcrumb %}
    {{ page.breadcrumb }}
  {% endif %}

  {% if page.highlighted %}
    <div class="highlighted">
      {{ page.highlighted }}
    </div>
  {% endif %}

  {% if page.help %}
    <div class="help">
      {{ page.help }}
    </div>
  {% endif %}

  <main role="main">
    <a id="main-content" tabindex="-1"></a>{# link is in html.html.twig #}
    <div class="layout-content">
      {{ page.content }} {# This is where the main page content (nodes, views, etc.) goes #}
    </div>
    {% if page.sidebar_first %}
      <aside class="layout-sidebar-first" role="complementary">
        {{ page.sidebar_first }} {# Renders the first sidebar region #}
      </aside>
    {% endif %}
    {% if page.sidebar_second %}
      <aside class="layout-sidebar-second" role="complementary">
        {{ page.sidebar_second }} {# Renders the second sidebar region #}
      </aside>
    {% endif %}
  </main>

  {% if page.footer %}
    <footer role="contentinfo">
      {{ page.footer }} {# Renders the footer region #}
    </footer>
  {% endif %}

</div>{# /.layout-container #}
